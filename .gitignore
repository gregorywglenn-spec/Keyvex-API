# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo
functions/lib/

# Secrets — service account JSON, env files, anything credential-shaped
secrets/
*.pem
*.key
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
.claude/
*.swp
*~

# Test coverage
coverage/
.nyc_output/

# Research scratch space (raw doc fetches, exploration outputs)
.research-tmp/

# Local scratch / workbench — one-off probes, progress JSON, scratch PDFs.
# NEVER commit: this folder is ~150MB of exploration scraps. Keeping it ignored
# is what prevents a careless `git add .` from bloating the repo permanently.
.tmp/
.tmp*

# OCR engine language data (re-downloadable; a 5MB binary blob, not source)
*.traineddata

# EDGAR index downloads (large, re-downloadable; probe/backfill scratch)
*.idx
# SEC company_tickers.json probe download (1MB, re-downloadable)
ct.json

# Firebase CLI deploy cache (auto-generated, rewrites on every hosting deploy)
.firebase/

# Reconcile scraper progress/state file (rewrites itself each run — not source)
scripts/backfill-queue.json

# Recent-window reconcile "extras" — for those adapters the extras column is
# all older records by design (pure noise), and it regenerates each run.
docs/reconciliation/*-recent-G1-extras.csv

# Index reconciliation scratch (read-only captures, re-generatable)
prod-indexes.json
prod-indexes.err

# throwaway one-off probe
scripts/probe-bad-dates.ts

# throwaway probes + scratch downloads
scripts/probe-registrations.ts
scripts/probe-circle.ts
scripts/probe-circle2.ts
circle-sub.json
prod-now.json
scripts/probe-nport-fresh.ts

# throwaway: live docs-page capture for accuracy review (curl scratch)
docs-live.html
