# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo
functions/lib/

# Secrets — service account JSON, env files, anything credential-shaped
secrets/
*.pem
*.key
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
.claude/
*.swp
*~

# Test coverage
coverage/
.nyc_output/

# Research scratch space (raw doc fetches, exploration outputs)
.research-tmp/

# Local scratch / workbench — one-off probes, progress JSON, scratch PDFs.
# NEVER commit: this folder is ~150MB of exploration scraps. Keeping it ignored
# is what prevents a careless `git add .` from bloating the repo permanently.
.tmp/
.tmp*

# OCR engine language data (re-downloadable; a 5MB binary blob, not source)
*.traineddata

# Firebase CLI deploy cache (auto-generated, rewrites on every hosting deploy)
.firebase/

# Reconcile scraper progress/state file (rewrites itself each run — not source)
scripts/backfill-queue.json

# Recent-window reconcile "extras" — for those adapters the extras column is
# all older records by design (pure noise), and it regenerates each run.
docs/reconciliation/*-recent-G1-extras.csv
